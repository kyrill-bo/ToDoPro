{
  "name": "todo",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"vite\"",
    "build": "vue-tsc -b && vite build && electron-builder",
    "preview": "vite preview",
    "server": "node server.js",
    "release": "standard-version"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kyrill-bo/ToDoPro.git"
  },
  "build": {
    "appId": "com.bobrashov.todo",
    "productName": "ToDo Pro",
    "publish": [
      {
        "provider": "github",
        "owner": "kyrill-bo",
        "repo": "ToDoPro"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "db.json"
    ],
    "mac": {
      "icon": "public/logo.jpg",
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "public/logo.jpg",
      "target": "nsis"
    },
    "linux": {
      "icon": "public/logo.jpg",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "body-parser": "^2.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.0",
    "pinia": "^3.0.4",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.5",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.32",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@types/marked": "^5.0.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.8",
    "standard-version": "^9.5.0",
    "tailwindcss": "3.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~6.0.2",
    "vite": "^6.4.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vue-tsc": "^3.2.6"
  }
}
